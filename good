#!/usr/bin/env bash
# good - Git + Goodview workflow helper
set -euo pipefail

VERSION="1.2.0"
GOOD_CLI_GITHUB_REPO="goodview-fr/good"
GOOD_CLI_GITHUB_REF="main"
GOOD_CLI_GITHUB_PATH="good"
GOOD_CLI_GITHUB_RAW="https://raw.githubusercontent.com/${GOOD_CLI_GITHUB_REPO}/${GOOD_CLI_GITHUB_REF}/${GOOD_CLI_GITHUB_PATH}"

_good_resolve_lib() {
    local script_dir candidate
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    for candidate in \
        "$script_dir/lib" \
        "${HOME}/.local/share/good/lib" \
        "/usr/local/share/good/lib"; do
        if [ -f "$candidate/common.sh" ]; then
            echo "$candidate"
            return 0
        fi
    done
    echo "Erreur: bibliothèque good introuvable (lib/common.sh)." >&2
    echo "Réinstalle avec: bash install-good.sh" >&2
    exit 1
}

GOOD_LIB="$(_good_resolve_lib)"
GOOD_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/common.sh
source "$GOOD_LIB/common.sh"
# shellcheck source=lib/git.sh
source "$GOOD_LIB/git.sh"
# shellcheck source=lib/goodview.sh
source "$GOOD_LIB/goodview.sh"
# shellcheck source=lib/ai.sh
source "$GOOD_LIB/ai.sh"
# shellcheck source=lib/telemetry.sh
source "$GOOD_LIB/telemetry.sh"
# shellcheck source=lib/commands.sh
source "$GOOD_LIB/dog.sh"
# shellcheck source=lib/commands.sh
source "$GOOD_LIB/commands.sh"

_good_parse_global_flags "$@"
if [ ${#REMAINING_ARGS[@]} -eq 0 ]; then
    _good_dispatch help
    exit 0
fi

_good_run_command "${REMAINING_ARGS[0]}" "${REMAINING_ARGS[@]:1}"
